# ============================================================
# Defi Ayiti -- Backend Django -- Variables d'environnement
# Copier ce fichier vers ".env" et renseigner les vraies valeurs.
# NE JAMAIS committer le fichier ".env" reel.
# ============================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-generate-a-strong-random-value
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
RENDER_EXTERNAL_HOSTNAME=

# --- Base de donnees Supabase (PostgreSQL) ---
# Recuperable dans Supabase > Project Settings > Database > Connection string (URI)
# Utiliser de preference le "connection pooler" (port 6543) fourni par Supabase.
DATABASE_URL=postgres://postgres:password@db.xxxxxxxxxxxx.supabase.co:6543/postgres
DB_CONN_MAX_AGE=60
DB_SSL_REQUIRE=True

# --- Supabase (API + Storage) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=defi-ayiti-media
USE_SUPABASE_STORAGE=True
# Cles S3 compatibles generees dans Supabase > Storage > S3 Access Keys
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_ENDPOINT_URL=https://xxxxxxxxxxxx.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1

# --- Redis (cache, Channels, Celery) ---
REDIS_URL=redis://localhost:6379/0

# --- Authentification sociale ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
GUEST_MODE_ENABLED=True

# --- CORS / Frontend ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# --- Email (production) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- Suivi d'erreurs (production, optionnel) ---
SENTRY_DSN=
